# ==========================================
# Phase 1: Build Web UI
# ==========================================
FROM node:22-alpine AS web-builder

WORKDIR /app/ui
COPY mcp-gateway-ui/package*.json ./
RUN npm ci
COPY mcp-gateway-ui/ ./
RUN npm run build

# ==========================================
# Phase 2: Build Rust Backend
# ==========================================
FROM rust:1.85-slim AS rust-builder

WORKDIR /app
RUN apt-get update && apt-get install -y pkg-config libssl-dev curl ca-certificates && rm -rf /var/lib/apt/lists/*
COPY mcp-gateway/ ./
RUN cargo build --release

# ==========================================
# Phase 3: Runtime Environment
# ==========================================
FROM debian:bookworm-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    nginx \
    nodejs \
    npm \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/*

RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY --from=rust-builder /app/target/release/gateway /usr/local/bin/mcp-gateway
COPY --from=web-builder /app/ui/dist /usr/share/nginx/html
COPY mcp-gateway/config.v2.json /opt/bootstrap/default-config.json
COPY .cursor/hf/nginx.conf /etc/nginx/conf.d/default.conf

RUN sed -i 's/"listen": "127.0.0.1:8765"/"listen": "127.0.0.1:8765"/g' /opt/bootstrap/default-config.json && \
    sed -i 's/"allowNonLoopback": false/"allowNonLoopback": false/g' /opt/bootstrap/default-config.json && \
    mkdir -p /data/config /data/skills /var/cache/nginx /var/log/nginx /var/lib/nginx /run

EXPOSE 7860

ENV RUST_LOG=info \
    HOME=/app \
    XDG_CONFIG_HOME=/app \
    MCP_GATEWAY_CONFIG=/data/config/config.json \
    MCP_SKILLS_ROOT=/data/skills \
    HF_SPACE_UI=1

CMD ["sh", "-c", "if [ ! -f \"$MCP_GATEWAY_CONFIG\" ]; then cp /opt/bootstrap/default-config.json \"$MCP_GATEWAY_CONFIG\"; fi && mcp-gateway run --config \"$MCP_GATEWAY_CONFIG\" > /tmp/mcp-gateway.log 2>&1 & exec nginx -g 'daemon off;'" ]
